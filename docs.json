{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "effy",
  "description": "effy is a multi-tenant agent manager built on eve: one deployment serves per-user agents, each session scoped to a verified (tenant, user) with its own persona, memory, and tools.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "quickstart",
          "architecture"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/multi-tenancy",
          "concepts/personas",
          "concepts/memory",
          "concepts/custom-tools"
        ]
      },
      {
        "group": "Integrate",
        "pages": [
          "guides/sdk",
          "guides/authentication",
          "guides/deployment"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/tools",
          "reference/configuration",
          "ai-tools"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/agentico-labs/effy",
          "icon": "github"
        },
        {
          "anchor": "eve framework",
          "href": "https://eve.dev/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/agentico-labs/effy"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/agentico-labs"
    }
  }
}
